# =============================================================================
# TheA21 — environment variables
# Copy this file to ".env.local" and fill in the values you have.
# In production (Vercel), add the same keys under Project → Settings → Environment Variables.
# Everything here is NEXT_PUBLIC_* (exposed to the browser) — do NOT put secrets/passwords here.
# =============================================================================

# Your live website URL. Used for SEO (sitemap, robots), the OG share-image
# absolute URL and the structured-data schema.
# IMPORTANT: set this to the domain you actually deploy to
# (e.g. https://thea21.vercel.app) until the thea21.in domain is connected,
# otherwise the OG banner and sitemap URLs will 404.
NEXT_PUBLIC_SITE_URL=https://thea21.in

# Web3Forms access key — free at https://web3forms.com
# Records every contact-form submission to your email so leads aren't lost if
# the visitor never sends the pre-filled WhatsApp message. Leave blank to disable.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google Analytics 4 Measurement ID — looks like G-XXXXXXXXXX
# Create a property at https://analytics.google.com. Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID — numeric, from Meta Events Manager.
# Needed to track conversions when running Facebook/Instagram ads. Leave blank to disable.
NEXT_PUBLIC_META_PIXEL_ID=
